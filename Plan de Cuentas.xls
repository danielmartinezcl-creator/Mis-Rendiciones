<TITLE>Informe de cuentas contables</TITLE>
<script type="text/javascript">
function MuestraMsg() {
	var objMsg = document.getElementsByName('MsgInicio');
	if (objMsg != null && objMsg.length == 1) {
		var sVal = objMsg[0].value;
		if (sVal != "") {
			objMsg[0].value = "";
			alert(sVal);
		}
	}
}
</script> 
